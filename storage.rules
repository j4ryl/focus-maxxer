rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /demo/hallOfFame/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource == null
        || (request.resource.size < 2 * 1024 * 1024
            && request.resource.contentType.matches('image/.*'));
    }
  }
}
